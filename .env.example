# Variables de entorno para Automatización Pastoral

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# Token de acceso de WhatsApp Cloud API
# Obtenido desde: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=tu_token_aqui

# Phone ID de WhatsApp Business
# Obtenido desde: https://developers.facebook.com/apps/
PHONE_ID=tu_phone_id_aqui

# ID del Google Sheet
# Es la parte larga en la URL del sheet: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
SHEET_ID=tu_sheet_id_aqui

# Google API Key con acceso a Google Sheets API
# Obtenido desde: https://console.cloud.google.com/
GOOGLE_API_KEY=tu_api_key_aqui
